# App server
ADRA_HOST=127.0.0.1
ADRA_PORT=8090
ADRA_AI_ENABLED=true

# LLM provider: gemini or ollama
ADRA_LLM_PROVIDER=gemini

# Ollama
OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434
OLLAMA_MODEL=gemma4:e2b

# Gemini API
# Keep your real key in .env. The .env file is ignored by git.
GEMINI_API_KEY=
GEMINI_MODEL=gemma-4-26b-a4b-it
GEMINI_API_HOST=generativelanguage.googleapis.com
GEMINI_API_PORT=443
